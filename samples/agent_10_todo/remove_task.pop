// remove_task.pop
// Demonstrates removing a task using filter

[] >> tasks.
{"id": 1, "title": "Buy Milk", "done": false} >+> tasks.
{"id": 2, "title": "Read Book", "done": false} >+> tasks.
{"id": 3, "title": "Write Code", "done": false} >+> tasks.

"--- Before Removal ---" >> Display.
tasks >> Display.

tasks >> Filter:
    @["id"] >> check:
        is 2: false.
        else: true.
    ..
.. >> filtered_tasks.

"--- After Removal ---" >> Display.
filtered_tasks >> Display.
