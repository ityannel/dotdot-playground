new QuickSort:
    @ >> arr.
    arr >> Length >> l.
    l >> check:
        is <= 1: arr.
        else:
            arr[0] >> pivot.
            arr >> Filter:
                @ < pivot.
            .. >> left.
            arr >> Filter:
                @ == pivot.
            .. >> mid.
            arr >> Filter:
                @ > pivot.
            .. >> right.
            
            left >> QuickSort >> sorted_left.
            right >> QuickSort >> sorted_right.
            
            [] >> result.
            sorted_left >> Map:
                @ >+> result.
            ..
            mid >> Map:
                @ >+> result.
            ..
            sorted_right >> Map:
                @ >+> result.
            ..
            result.
    ..
..

[38, 27, 43, 3, 9, 82, 10, 19, 50, 4] >> QuickSort >> sorted.
"Sorted: " >> out.
(sorted >> ToJson) >+> out >> Display.
