{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PopPop",
  "patterns": [
    { "include": "#comments" },
    { "include": "#operators" },
    { "include": "#keywords" },
    { "include": "#uppercase-functions" },
    { "include": "#lowercase-variables" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#implicit-var" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.poppop",
          "match": "//.*$"
        },
        {
          "name": "comment.block.poppop",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.poppop",
          "match": ">>|>!>|>~>|>\\+>|>\\?>"
        },
        {
          "name": "punctuation.accessor.poppop",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.poppop",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.poppop",
          "match": "&&|\\b(and|or)\\b|\\|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.poppop",
          "match": "\\+|\\-|\\*|\\/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.poppop",
          "match": "\\b(check|Check|is|else|fork|route|tap|error|join|flat|pack|new|return|catch|Catch|loop|break|as|from|silo|connect|must|be|not)\\b"
        },
        {
          "name": "support.function.builtin.poppop",
          "match": "\\b(Display|Input|Fetch|PostFetch|WriteFile|Serve|Fail|Set|Merge|Num|Str|Bool|List|Dict|Type|Sleep|Add|Sum|Max|Min|Average|Round|Abs|Length|Sort|Reverse|Uppercase|Lowercase|Split|Replace|Join|Get|Contains|Append|Slice|Format|Now|Random|ToJson|FromJson|Clear|RenderFrame|GetKey|ScrapeDormMenu|ScrapeMenu|Import|Int|Array|Range|Return|Break|Group|Debug|Lazy|Take|Count|Throw|Update|Drop|Map|Filter|Reduce|Zip|Loop|Do)\\b"
        },
        {
          "name": "constant.language.poppop",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "support.type.poppop",
          "match": "\\b(int|str|bool|list|dict)\\b"
        }
      ]
    },
    "uppercase-functions": {
      "patterns": [
        {
          "name": "entity.name.function.poppop",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "lowercase-variables": {
      "patterns": [
        {
          "name": "variable.other.readwrite.poppop",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "implicit-var": {
      "patterns": [
        {
          "name": "variable.language.implicit.poppop",
          "match": "@"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.poppop",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.poppop",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolated.poppop",
              "match": "\\{[^\\}]+\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.poppop",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    }
  },
  "scopeName": "source.poppop"
}
